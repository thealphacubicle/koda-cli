    typewrite(f"{CYAN}new{RESET}", delay=0.01)
    typewrite("  koda new <name> --> Create a new project (interactive)", delay=0.01)
    typewrite(f"{CYAN}auth{RESET}", delay=0.01)
    typewrite("  koda auth --> Check gh and Claude Code setup", delay=0.01)
    typewrite(f"{CYAN}config{RESET}", delay=0.01)
    typewrite("  koda config --> Show or set API keys", delay=0.01)
    typewrite("  koda config set <provider> --> Set API key for anthropic, openai, or google", delay=0.01)
    typewrite(f"{CYAN}help{RESET}", delay=0.01)
    typewrite("  koda help --> Show this help", delay=0.01)
    typewrite(f"{CYAN}clear{RESET}", delay=0.01)
    typewrite("  clear --> Clear terminal and redraw banner", delay=0.01)
