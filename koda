import re

# Add script directory to path for imports
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, SCRIPT_DIR)

from core.utils import typewrite, typewrite_no_newline, print_divider, CYAN, GREEN, RED, YELLOW, DIM, RESET
from core.auth import check_all
from core.prompt import select, multiselect, confirm, text_input
from core.scaffold import create_project
from core.ai import ask_ai, CONFIG_PATH, _load_config, _save_config, CONFIG_KEYS
from core.git import init_repo, first_commit, create_and_push
from core.banner import show_banner
from core.repl import start_repl

VERSION = "1.0.0"


