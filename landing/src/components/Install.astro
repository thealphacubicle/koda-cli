---
const baseUrl = (import.meta.env.BASE_URL || '/koda-cli').replace(/\/$/, '') || '/koda-cli';
const steps = [
  {
    num: 1,
    label: 'Install',
    title: 'Install koda',
    code: 'pip install git+https://github.com/thealphacubicle/koda-cli.git',
    id: 'install-step-1',
  },
  {
    num: 2,
    label: 'Configure',
    title: 'Add your AI API key (one-time)',
    code: 'koda config set anthropic',
    id: 'install-step-2',
  },
  {
    num: 3,
    label: 'Create',
    title: 'Bootstrap your first project',
    code: 'koda new my-project',
    id: 'install-step-3',
  },
];
---

<section class="bg-github-surface border-y border-github-border py-24">
  <div class="max-w-[600px] mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-semibold text-github-text text-center mb-4">Get started in three steps</h2>
    <p class="text-github-muted text-sm text-center mb-16">You'll need Python 3.9+, git, and an API key from <a href="https://console.anthropic.com" target="_blank" rel="noopener noreferrer" class="text-github-cyan hover:underline">Claude</a>, <a href="https://platform.openai.com/api-keys" target="_blank" rel="noopener noreferrer" class="text-github-cyan hover:underline">OpenAI</a>, or <a href="https://aistudio.google.com/apikey" target="_blank" rel="noopener noreferrer" class="text-github-cyan hover:underline">Gemini</a>. For GitHub push: install the <a href="https://cli.github.com" target="_blank" rel="noopener noreferrer" class="text-github-cyan hover:underline">gh CLI</a>.</p>

    <div class="relative">
      {steps.map((step, i) => (
        <div class="install-step flex gap-6 pb-12 last:pb-0 opacity-0 translate-y-4 transition-all duration-500 ease-out" data-step={step.id}>
          <!-- Left: timeline -->
          <div class="flex flex-col items-center shrink-0">
            <div class="w-8 h-8 rounded-full bg-github-cyan flex items-center justify-center text-github-bg font-bold text-sm">
              {step.num}
            </div>
            {i < steps.length - 1 && (
              <div class="w-0.5 flex-1 min-h-[60px] border-l-2 border-dotted border-github-border mt-2"></div>
            )}
          </div>

          <!-- Right: content -->
          <div class="flex-1 min-w-0 pt-0.5">
            <p class="text-github-cyan text-xs font-mono tracking-widest uppercase">{step.label}</p>
            <p class="text-github-text font-bold mt-1">{step.title}</p>
            <div class="mt-3 bg-github-bg border border-github-border rounded-lg p-4 font-mono text-sm text-github-cyan relative overflow-x-auto">
              <button
                type="button"
                class="copy-btn border border-github-border rounded px-2 py-1 text-xs text-github-muted hover:text-github-text transition absolute top-2 right-2 shrink-0"
                data-code={step.code}
              >
                copy
              </button>
              <code class="block pr-16 whitespace-nowrap">{step.code}</code>
            </div>
          </div>
        </div>
      ))}
    </div>
    <p class="text-center mt-12">
      <a href={`${baseUrl}/docs`} class="text-github-cyan hover:underline text-sm font-medium">Full setup guide →</a>
    </p>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const copyBtns = document.querySelectorAll('.copy-btn')
    copyBtns.forEach((btn) => {
      const code = btn.dataset.code
      if (!code) return
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code)
          const orig = btn.textContent
          btn.textContent = '✓'
          setTimeout(() => { btn.textContent = orig }, 2000)
        } catch {}
      })
    })

    const steps = document.querySelectorAll('.install-step')
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry, idx) => {
          if (entry.isIntersecting) {
            const step = entry.target
            const index = Array.from(steps).indexOf(step)
            const delay = index * 100
            setTimeout(() => {
              step.classList.remove('opacity-0', 'translate-y-4')
              step.classList.add('opacity-100', 'translate-y-0')
            }, delay)
          }
        })
      },
      { threshold: 0.2, rootMargin: '0px 0px -50px 0px' }
    )
    steps.forEach((s) => observer.observe(s))
  })
</script>
