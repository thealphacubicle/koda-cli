---
// Minimal frontmatter - animation logic lives in inline script
---

<div class="max-w-3xl mx-auto px-4 py-16">
  <div class="rounded-xl border border-github-border bg-github-surface shadow-2xl overflow-hidden">
    <div class="flex items-center gap-2 px-4 py-3 border-b border-github-border bg-github-bg">
      <span class="w-3 h-3 rounded-full bg-github-red"></span>
      <span class="w-3 h-3 rounded-full bg-github-yellow"></span>
      <span class="w-3 h-3 rounded-full bg-github-green"></span>
      <span class="mx-auto font-mono text-sm text-github-muted">koda — zsh</span>
    </div>
    <div id="terminal-body" class="p-6 font-mono text-sm leading-relaxed overflow-y-auto" style="min-height: 300px;"></div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const terminal = document.getElementById('terminal-body')
    if (!terminal) return

    const sequence = [
      { text: '$ koda new my-project', color: '#e6edf3', delay: 800, typewriter: true },
      { text: '', color: '', delay: 300 },
      { text: '╭─── ⚒ Koda v1.0.0 ───────────────────╮', color: '#00b4d8', delay: 200 },
      { text: '│  Welcome back, thealphacubicle!      │', color: '#00b4d8', delay: 100 },
      { text: '╰──────────────────────────────────────╯', color: '#00b4d8', delay: 100 },
      { text: '', color: '', delay: 200 },
      { text: '  What type of project?', color: '#8b949e', delay: 300 },
      { text: '  ❯ Python data science', color: '#d29922', delay: 150 },
      { text: '    Python API / backend', color: '#8b949e', delay: 100 },
      { text: '    Web app (HTML/JS)', color: '#8b949e', delay: 100 },
      { text: '', color: '', delay: 500 },
      { text: '  Which AI provider?', color: '#8b949e', delay: 200 },
      { text: '  ❯ Claude (Anthropic)', color: '#d29922', delay: 150 },
      { text: '    ChatGPT (OpenAI)', color: '#8b949e', delay: 100 },
      { text: '    Gemini (Google)', color: '#8b949e', delay: 100 },
      { text: '', color: '', delay: 400 },
      { text: '  ✓ Checking tools...', color: '#8b949e', delay: 200 },
      { text: '  ✓ gh CLI         — logged in', color: '#3fb950', delay: 300 },
      { text: '  ✓ Claude Code    — authenticated', color: '#3fb950', delay: 200 },
      { text: '', color: '', delay: 200 },
      { text: '  ✓ Creating project structure...', color: '#3fb950', delay: 300 },
      { text: '  ✓ Asking Claude to write starter code...', color: '#3fb950', delay: 600 },
      { text: '  ✓ Writing README.md...', color: '#3fb950', delay: 400 },
      { text: '  ✓ Git init + first commit...', color: '#3fb950', delay: 300 },
      { text: '  ✓ Created GitHub repo: thealphacubicle/my-project', color: '#3fb950', delay: 400 },
      { text: '  ✓ Pushed to GitHub', color: '#3fb950', delay: 300 },
      { text: '', color: '', delay: 200 },
      { text: '  🚀 Done! Ready at ~/Desktop/Projects/my-project', color: '#e6edf3', delay: 400 },
    ]

    async function sleep(ms) {
      return new Promise(resolve => setTimeout(resolve, ms))
    }

    async function typewriterLine(text, color) {
      const line = document.createElement('div')
      line.style.color = color
      terminal.appendChild(line)
      for (const char of text) {
        line.textContent += char
        await sleep(30)
      }
    }

    async function printLine(text, color) {
      const line = document.createElement('div')
      line.style.color = color || 'transparent'
      line.textContent = text || '\u00A0'
      terminal.appendChild(line)
    }

    async function playSequence() {
      terminal.innerHTML = ''
      for (const item of sequence) {
        await sleep(item.delay)
        if (item.typewriter) {
          await typewriterLine(item.text, item.color)
        } else {
          await printLine(item.text, item.color)
        }
        terminal.scrollTop = terminal.scrollHeight
      }

      // blinking cursor
      const cursor = document.createElement('span')
      cursor.textContent = '█'
      cursor.style.color = '#00b4d8'
      cursor.style.animation = 'blink 1s step-end infinite'
      terminal.appendChild(cursor)

      // restart after 3 seconds
      await sleep(3000)
      playSequence()
    }

    // add blink keyframe
    const style = document.createElement('style')
    style.textContent = '@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }'
    document.head.appendChild(style)

    playSequence()
  })
</script>
